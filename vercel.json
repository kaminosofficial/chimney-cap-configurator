{
    "buildCommand": "npm run build:vercel",
    "outputDirectory": "dist",
    "crons": [
        {
            "path": "/api/cleanup-variants",
            "schedule": "0 0 */10 * *"
        }
    ],
    "headers": [
        {
            "source": "/chase-cover-configurator.iife.js",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=60, s-maxage=300"
                }
            ]
        },
        {
            "source": "/chase-configurator.iife.js",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=60, s-maxage=300"
                }
            ]
        },
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET, POST, OPTIONS"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type"
                }
            ]
        }
    ],
    "functions": {
        "api/add-to-cart.ts": { "maxDuration": 30 },
        "api/variant-image.ts": { "maxDuration": 25 }
    },
    "rewrites": [
        {
            "source": "/chase-cover-configurator.iife.js",
            "destination": "/chase-cover-configurator.iife.js"
        },
        {
            "source": "/chase-configurator.iife.js",
            "destination": "/chase-configurator.iife.js"
        }
    ]
}
