{
  "name": "chase-cover-configurator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "sync:shopify-css": "node scripts/sync-shopify-css.mjs",
    "build:shopify": "npm run sync:shopify-css && cross-env BUILD_TARGET=shopify vite build",
    "build:vercel": "npm run build && npm run build:shopify && node -e \"const fs=require('fs'); fs.copyFileSync('dist-shopify/chase-cover-configurator.iife.js','dist/chase-cover-configurator.iife.js'); fs.copyFileSync('dist-shopify/chase-cover-configurator.iife.js','dist/chase-configurator.iife.js');\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "qrious": "^4.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.2",
    "three-csg-ts": "^3.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vercel/node": "^5.6.11",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  }
}
